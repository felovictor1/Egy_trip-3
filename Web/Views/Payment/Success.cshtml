@{
    ViewData["Title"] = "Payment Successful";
    var hotelName    = ViewData["HotelName"]?.ToString()    ?? "Hotel";
    var total        = ViewData["TotalAmount"]?.ToString()  ?? "0";
    var nights       = ViewData["Nights"]?.ToString()       ?? "1";
    var savedPlanId  = ViewData["SavedPlanId"]?.ToString()  ?? "0";
    var currentTitle = ViewData["CurrentTitle"]?.ToString() ?? "";
}

<style>
    @@keyframes pop-in {
        0%   { transform: scale(0.5); opacity: 0; }
        70%  { transform: scale(1.1); }
        100% { transform: scale(1);   opacity: 1; }
    }
    .pop-in { animation: pop-in 0.5s cubic-bezier(.36,.07,.19,.97) both; }

    @@keyframes slide-up {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
    .slide-up { animation: slide-up 0.4s ease 0.3s both; }

    @@keyframes confetti-fall {
        0%   { transform: translateY(-20px) rotate(0deg);   opacity: 1; }
        100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
    }
    .confetti-piece {
        position: fixed;
        animation: confetti-fall 3s ease-in forwards;
        pointer-events: none;
    }

    #rename-input:focus {
        outline: none;
        box-shadow: 0 0 0 3px rgba(247,147,26,0.35);
    }
    #save-name-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-orange-50 dark:from-[#0F172A] dark:to-[#1a2540] flex items-center justify-center px-4 py-12">
    <div class="max-w-md w-full space-y-5">

        @* Receipt card *@
        <div class="pop-in bg-white dark:bg-slate-800 rounded-3xl shadow-2xl p-10 text-center border border-gray-100 dark:border-white/10">

            @* Animated checkmark *@
            <div class="mx-auto mb-5 w-24 h-24 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
            </div>

            <h1 class="text-3xl font-extrabold text-navy dark:text-white mb-1">Payment Successful! 🎉</h1>
            <p class="text-gray-500 dark:text-gray-400 mb-6">Your hotel has been booked. Get ready for your trip to Egypt!</p>

            @* Receipt *@
            <div class="bg-gray-50 dark:bg-slate-700/50 rounded-2xl p-5 text-left border border-gray-100 dark:border-white/10">
                <div class="flex items-start gap-3 mb-4">
                    <span class="text-2xl">🏨</span>
                    <div>
                        <p class="font-bold text-navy dark:text-white text-base leading-tight">@hotelName</p>
                        <p class="text-gray-500 dark:text-gray-400 text-sm">@nights night(s)</p>
                    </div>
                </div>
                <div class="flex justify-between items-center pt-3 border-t border-gray-200 dark:border-white/10">
                    <span class="text-gray-600 dark:text-gray-300 font-medium text-sm">Total Paid</span>
                    <span class="text-xl font-extrabold text-green-600 dark:text-green-400">@total EGP</span>
                </div>
            </div>
        </div>

        @* Naming card *@
        <div class="slide-up bg-white dark:bg-slate-800 rounded-3xl shadow-xl p-8 border border-gray-100 dark:border-white/10">
            <div class="flex items-center gap-3 mb-5">
                <div class="w-10 h-10 rounded-xl bg-orange/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
                    </svg>
                </div>
                <div>
                    <h2 class="text-lg font-bold text-navy dark:text-white m-0">Name Your Trip</h2>
                    <p class="text-gray-500 dark:text-gray-400 text-sm m-0">Give it a name so you can find it in My Plans</p>
                </div>
            </div>

            <div class="flex gap-2">
                <input id="rename-input"
                       type="text"
                       maxlength="80"
                       placeholder="e.g. Honeymoon in Cairo 🌙"
                       value="@currentTitle"
                       class="flex-grow rounded-xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-slate-700 text-navy dark:text-white placeholder-gray-400 px-4 py-3 text-sm transition-all" />
                <button id="save-name-btn"
                        class="bg-orange hover:bg-orange/90 text-white font-bold px-5 py-3 rounded-xl shadow-md shadow-orange/20 transition-all hover:shadow-lg active:scale-95 whitespace-nowrap text-sm">
                    Save ✓
                </button>
            </div>

            <p id="rename-feedback" class="mt-3 text-sm hidden"></p>
        </div>

        @* Navigation *@
        <div class="slide-up flex gap-3">
            <a href="/planner"
               class="flex-1 bg-white dark:bg-slate-800 border border-gray-200 dark:border-white/10 text-navy dark:text-white font-bold py-3 px-4 rounded-xl transition-all hover:shadow-md text-center text-sm">
                Plan Another Trip
            </a>
            <a href="/MyPlans"
               class="flex-1 bg-orange hover:bg-orange/90 text-white font-bold py-3 px-4 rounded-xl shadow-md shadow-orange/20 transition-all hover:shadow-lg text-center text-sm">
                My Plans →
            </a>
        </div>
    </div>
</div>

<script>
    // Confetti burst
    const colors = ['#F7931A','#22c55e','#3b82f6','#f59e0b','#ec4899','#a78bfa'];
    for (let i = 0; i < 60; i++) {
        const el = document.createElement('div');
        el.className = 'confetti-piece';
        el.style.cssText = `
            left: ${Math.random() * 100}vw;
            top: -10px;
            background: ${colors[Math.floor(Math.random() * colors.length)]};
            border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
            animation-delay: ${Math.random() * 1.5}s;
            animation-duration: ${2 + Math.random() * 2}s;
            width:  ${6 + Math.random() * 10}px;
            height: ${6 + Math.random() * 10}px;
        `;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 5000);
    }

    // Trip naming
    const savedPlanId = @savedPlanId;
    const btn         = document.getElementById('save-name-btn');
    const input       = document.getElementById('rename-input');
    const feedback    = document.getElementById('rename-feedback');

    function showFeedback(msg, success) {
        feedback.textContent = msg;
        feedback.className   = `mt-3 text-sm ${success ? 'text-green-600 dark:text-green-400' : 'text-red-500'}`;
    }

    async function saveName() {
        const title = input.value.trim();
        if (!title) { showFeedback('Please enter a name for your trip.', false); return; }

        btn.disabled   = true;
        btn.textContent = 'Saving…';

        try {
            const res = await fetch('/Payment/RenamePlan', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ savedPlanId, title })
            });
            const data = await res.json();
            if (data.success) {
                showFeedback('✓ Trip name saved! You can find it in My Plans.', true);
                btn.textContent = 'Saved ✓';
            } else {
                showFeedback('Something went wrong. Please try again.', false);
                btn.disabled    = false;
                btn.textContent = 'Save ✓';
            }
        } catch {
            showFeedback('Network error. Please try again.', false);
            btn.disabled    = false;
            btn.textContent = 'Save ✓';
        }
    }

    btn.addEventListener('click', saveName);
    input.addEventListener('keydown', e => { if (e.key === 'Enter') saveName(); });
</script>
