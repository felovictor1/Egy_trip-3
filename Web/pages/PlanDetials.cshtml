@page "{id:int}"
@model eg_travil.pages.PlanDetailsModel
@{
    ViewData["Title"] = Model.Plan?.Title ?? "Plan Details";
}

<div class="bg-white dark:bg-[#0F172A] min-h-screen transition-colors duration-300">
    @if (Model.Plan != null)
    {
        <div class="relative h-[450px] w-full">
            <img src="@(Model.Plan.PhotoPath ?? "https://images.unsplash.com/photo-1503177119275-0aa32b3a9368?w=1600")"
                 class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 flex items-end">
                <div class="max-w-7xl mx-auto px-6 pb-12 w-full">
                    <a href="/ReadyPlans" class="text-white/80 hover:text-white mb-4 inline-block text-sm">← Back to Plans</a>
                    <h1 class="text-4xl md:text-6xl font-bold text-white">@Model.Plan.Title</h1>
                </div>
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-3 gap-16">
            <div class="lg:col-span-2 space-y-12">
                <section>
                    <h2 class="text-3xl font-bold text-navy dark:text-white mb-6">Overview</h2>
                    <p class="text-gray-700 dark:text-gray-300 whitespace-pre-line leading-relaxed text-lg">@Model.Plan.Description</p>
                </section>
                <section class="bg-slate-50 dark:bg-white/5 p-10 rounded-[2.5rem] border border-transparent dark:border-white/10 transition-colors duration-300">
                    <h2 class="text-3xl font-bold text-navy dark:text-white mb-8">Itinerary</h2>
                    <div class="text-gray-600 dark:text-gray-300 whitespace-pre-line leading-loose">@Model.Plan.Itinerary</div>
                </section>
            </div>

            <div class="space-y-8">
                <div class="bg-navy dark:bg-black/40 border border-transparent dark:border-white/10 rounded-[2.5rem] p-10 text-white transition-colors duration-300">
                    <h3 class="text-2xl font-bold mb-6">What's Included</h3>
                    <div class="text-slate-300 dark:text-slate-200 whitespace-pre-line text-sm mb-8">@Model.Plan.Inclusions</div>
                    <hr class="my-8 border-white/10" />
                    <h3 class="text-2xl font-bold mb-6 text-orange">Not Included</h3>
                    <div class="text-slate-300 whitespace-pre-line text-sm">@Model.Plan.Exclusions</div>
                </div>
            </div>
        </div>
    }
</div>