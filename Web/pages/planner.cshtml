@page
@model eg_travil.Pages.PlannerModel
@{
    ViewData["Title"] = "AI Travel Planner";
    var cities = new[] {
        new { Label = "Cairo & Giza", Img = "data:image/jpeg;base64," },
        new { Label = "Luxor", Img = "data:image/jpeg;base64," },
        new { Label = "Aswan", Img = "data:image/jpeg;base64," },
        new { Label = "Alexandria", Img = "data:image/jpeg;base64," },
        new { Label = "Sharm El-Sheikh", Img = "data:image/jpeg;base64," },
        new { Label = "Siwa Oasis", Img = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRnsxmFw70sznZCS3wZgztSh78JRaroWNjZNg&s" }
    };
}

<style>
    :root {
        --navy: #1a2a44;
        --orange: #ff8c00;
        --orange-hover: #e67e00;
        --beige: #f5f5f0;
        --light-blue: #f0f4f8;
        --text-color: #333;
    }

    body {
        background: linear-gradient(135deg, var(--beige) 0%, var(--light-blue) 100%);
        background-attachment: fixed;
        color: var(--text-color);
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .planner-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 1.5rem;
        padding: 3rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .card-img-top {
        height: 160px;
        object-fit: cover;
        border-bottom: 1px solid #eee;
    }

    .destination-card {
        cursor: pointer;
        border: 2px solid transparent !important;
        border-radius: 1rem;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        overflow: hidden;
        height: 100%;
        background: #ffffff;
        box-shadow: 0 4px 6px rgba(0,0,0,0.04);
    }

        .destination-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

        .destination-card.selected {
            border-color: var(--orange) !important;
            background-color: #fffaf0;
            box-shadow: 0 0 0 4px rgba(255, 140, 0, 0.1) !important;
            transform: scale(1.02);
        }

        .destination-card h6, .destination-card span {
            font-weight: 700;
            color: var(--navy);
            margin: 0;
        }

    .step-content {
        display: none;
    }

        .step-content.active {
            display: block;
            animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .btn-orange {
        background: linear-gradient(135deg, var(--orange) 0%, #ff6b00 100%);
        color: white;
        border-radius: 0.75rem;
        font-weight: bold;
        padding: 12px 35px;
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 140, 0, 0.3);
    }

    .btn-orange:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 140, 0, 0.4);
        color: white;
    }
    
    .btn-light {
        border-radius: 0.75rem;
        font-weight: bold;
        padding: 12px 35px;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
    }
    
    .btn-light:hover {
        background-color: #e2e6ea;
        transform: translateY(-2px);
    }

    /* Form Controls */
    .form-control, .form-select {
        border-radius: 0.75rem;
        padding: 0.75rem 1rem;
        border: 2px solid #eef0f2;
        transition: all 0.3s ease;
        background-color: #fcfcfd;
    }
    
    .form-control:focus, .form-select:focus {
        border-color: var(--orange);
        box-shadow: 0 0 0 0.25rem rgba(255, 140, 0, 0.15);
        background-color: #fff;
    }

    /* Loading Overlay Styles */
    #loadingOverlay {
        display: none;
        text-align: center;
        padding: 50px;
    }
    
    #loadingOverlay .spinner-border {
        width: 4rem;
        height: 4rem;
        border-width: 0.25em;
    }

    /* Dark Mode Overrides */
    html.dark body {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        background-attachment: fixed;
        color: #f1f5f9;
    }

    html.dark .planner-card {
        background: rgba(30, 41, 59, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    html.dark .destination-card {
        background: rgba(255, 255, 255, 0.05);
    }
    
    html.dark .destination-card:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    html.dark .destination-card.selected {
        background-color: rgba(255, 140, 0, 0.1);
    }

    html.dark .destination-card h6, 
    html.dark .destination-card span, 
    html.dark .destination-card h5, 
    html.dark .destination-card h4, 
    html.dark .destination-card h3,
    html.dark .text-navy {
        color: #f8fafc !important;
    }

    html.dark .text-gray-500, html.dark .text-gray-600 {
        color: #cbd5e1 !important;
    }

    html.dark .form-control, html.dark .form-select {
        background-color: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
        color: #f8fafc;
    }

    html.dark .form-control:focus, html.dark .form-select:focus {
        background-color: rgba(30, 41, 59, 1);
        color: white;
    }

    html.dark .btn-light {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.1);
        color: white;
    }
    html.dark .btn-light:hover {
        background-color: rgba(255, 255, 255, 0.2);
    }

    html.dark .bg-white {
        background-color: rgba(255,255,255,0.05) !important;
    }
    html.dark .bg-gray-50, html.dark .bg-blue-50 {
        background-color: rgba(255,255,255,0.02) !important;
    }
</style>

<div class="container py-5">
    @if (Model.GeneratedPlan == null)
    {
        @* --- PLANNER FORM VIEW --- *@
        <div class="flex justify-center">
            <div class="w-full max-w-4xl">
                <div class="planner-card p-5 border-0 shadow-lg">
                    <div class="flex justify-between mb-3 items-end">
                        <span class="font-bold text-navy text-xl" id="stepText">Step 1 of 8</span>
                        <span class="font-bold text-orange-500 text-base" id="progressText">13% Complete</span>
                    </div>
                    <div class="w-full mb-5" style="height: 8px; border-radius: 10px; background-color: #f0f0f0; overflow: hidden;">
                        <div id="pBar" style="background-color: var(--orange); width: 12.5%; transition: width 0.4s ease; height: 100%;"></div>
                    </div>

                    <form method="post" id="plannerForm">
                        <!-- STEP 1: Destinations -->
                        <div class="step-content active" id="step1">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Where to?</h1>
                            <p class="text-gray-500 mb-5 text-lg">Select your Egyptian destinations</p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-8">
                                @foreach (var city in cities)
                                {
                                    <div class="destination-card border-none bg-white shadow-sm flex flex-col cursor-pointer transition-all duration-300 hover:-translate-y-2 hover:shadow-xl ring-2 ring-transparent" onclick="selectCard(this)" style="border-radius: 1rem; overflow: hidden;">
                                        <img src="@city.Img" class="w-full object-cover" alt="@city.Label" style="height: 180px;">
                                        <div class="p-4 flex flex-col justify-center items-center">
                                            <h5 class="font-bold text-lg m-0 text-navy">@city.Label</h5>
                                            <input type="checkbox" name="Preferences.Destinations" value="@city.Label" class="hidden">
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mt-5 flex justify-end">
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(2)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 2: Dates -->
                        <div class="step-content" id="step2">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">When are you traveling?</h1>
                            <p class="text-gray-500 mb-5 text-lg">Select your start and end dates</p>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Start Date</label>
                                    <input type="date" asp-for="Preferences.StartDate" class="form-control" required>
                                </div>
                                <div>
                                    <label class="block font-bold mb-2 text-lg">End Date</label>
                                    <input type="date" asp-for="Preferences.EndDate" class="form-control" required>
                                </div>
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(1)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(3)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 3: Travelers -->
                        <div class="step-content" id="step3">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Who is traveling?</h1>
                            <p class="text-gray-500 mb-5 text-lg">Tell us about your group</p>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Adults</label>
                                    <input type="number" asp-for="Preferences.Travelers.Adults" class="form-control" min="1" value="2" required>
                                </div>
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Children (0-12)</label>
                                    <input type="number" asp-for="Preferences.Travelers.Kids" class="form-control" min="0" value="0">
                                </div>
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(2)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(4)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 4: Budget -->
                        <div class="step-content" id="step4">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Total Budget?</h1>
                            <p class="text-gray-500 mb-5 text-lg">Select a budget range for the entire trip</p>

                            <div id="budgetRangesContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                                <div class="text-center py-8 col-span-full">
                                    <p class="text-gray-500">Loading budget options...</p>
                                </div>
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(3)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(5)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 5: Travel Style -->
                        <div class="step-content" id="step5">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Travel Style</h1>
                            <p class="text-gray-500 mb-5 text-lg">Select the main focus of your trip</p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8" id="travelStylesGrid">
                                @{
                                    var styles = new[] { "Cultural", "Historical", "Nature", "Sea & Beach", "Adventure / Safari", "Food & Dining", "Shopping", "Nightlife" };
                                }
                                @foreach (var style in styles)
                                {
                                    <div class="destination-card travel-style-card p-4 text-center shadow-sm flex items-center justify-center cursor-pointer transition-all bg-white rounded-xl" data-style="@style" onclick="selectCard(this); handleStyleChange()">
                                        <h5 class="font-bold text-lg m-0">@style</h5>
                                        <input type="checkbox" name="Preferences.TravelStyles" value="@style" class="hidden">
                                    </div>
                                }
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(4)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(6)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 6: Dynamic Branches -->
                        <div class="step-content" id="step6">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Tailoring Your Experience</h1>
                            <p class="text-gray-500 mb-5 text-lg">Let's refine your itinerary</p>
                            
                            <div id="dynamicContentContainer">
                                <!-- Sea & Beach Options -->
                                <div id="seaAndBeachFields" style="display: none;" class="mb-8 p-4 bg-gray-50 rounded-xl">
                                    <h4 class="font-bold mb-4 text-navy">Would you like to try water activities?</h4>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div class="destination-card p-4 text-center shadow-sm cursor-pointer bg-white rounded-xl" onclick="selectRadio(this)">
                                            <h4 class="font-bold text-lg m-0">Yes, please!</h4>
                                            <input type="radio" name="Preferences.WantsWaterActivities" value="true" class="hidden">
                                        </div>
                                        <div class="destination-card p-4 text-center shadow-sm cursor-pointer bg-white rounded-xl" onclick="selectRadio(this)">
                                            <h4 class="font-bold text-lg m-0">No, just relaxing.</h4>
                                            <input type="radio" name="Preferences.WantsWaterActivities" value="false" class="hidden">
                                        </div>
                                    </div>
                                </div>

                                <!-- Cultural/Historical Options -->
                                <div id="culturalFields" style="display: none;" class="mb-8 p-4 bg-gray-50 rounded-xl">
                                    <h4 class="font-bold mb-3 text-navy">Your Historical Knowledge</h4>
                                    <select asp-for="Preferences.HistoricalKnowledge" class="form-select mb-6">
                                        <option value="">Select Level</option>
                                        <option value="Beginner">Beginner (Just the highlights)</option>
                                        <option value="Intermediate">Intermediate (Know some history)</option>
                                        <option value="Expert">Expert (Want deep dives)</option>
                                    </select>

                                    <h4 class="font-bold mb-3 mt-4 text-navy">Preferred Tourism Style</h4>
                                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                                        @foreach (var period in new[] { "Pharaonic", "Islamic", "Coptic", "Modern" })
                                        {
                                            <div class="destination-card p-3 text-center shadow-sm cursor-pointer bg-white rounded-xl" onclick="selectCard(this)">
                                                <span class="font-bold">@period</span>
                                                <input type="checkbox" name="Preferences.PreferredTourismStyle" value="@period" class="hidden">
                                            </div>
                                        }
                                    </div>

                                    <h4 class="font-bold mb-3 text-navy">Museum visits?</h4>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                        <div class="destination-card p-4 text-center shadow-sm cursor-pointer bg-white rounded-xl" onclick="selectRadio(this)">
                                            <h5 class="font-bold text-lg m-0">Yes</h5>
                                            <input type="radio" name="Preferences.MuseumPreferences" value="true" class="hidden">
                                        </div>
                                        <div class="destination-card p-4 text-center shadow-sm cursor-pointer bg-white rounded-xl" onclick="selectRadio(this)">
                                            <h5 class="font-bold text-lg m-0">No</h5>
                                            <input type="radio" name="Preferences.MuseumPreferences" value="false" class="hidden">
                                        </div>
                                    </div>
                                </div>
                                
                                <div id="noDynamicFields" style="display: none;">
                                    <div class="p-5 text-center mt-4 bg-blue-50 rounded-xl">
                                        <h4 class="font-bold text-navy mb-2">No extra questions required!</h4>
                                        <p class="text-gray-600 m-0">You can move forward.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(5)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(7)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 7: Accommodation -->
                        <div class="step-content" id="step7">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Accommodation</h1>
                            <p class="text-gray-500 mb-5 text-lg">Where would you like to stay?</p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                                @{
                                    var accOptions = new[] {
                                        new { v = "Budget", l = "Hostel / Budget" },
                                        new { v = "Medium", l = "Mid-Range (3-4 Stars)" },
                                        new { v = "Luxury", l = "Luxury (5 Stars)" },
                                        new { v = "Local", l = "Local Guesthouses" }
                                    };
                                }
                                @foreach (var opt in accOptions)
                                {
                                    <div class="destination-card accommodation-card p-5 text-center shadow-sm flex items-center justify-center cursor-pointer transition-all bg-white rounded-xl" data-label="@opt.l" onclick="selectRadio(this)">
                                        <h3 class="font-bold text-xl m-0 text-navy">@opt.l</h3>
                                        <input type="radio" asp-for="Preferences.Accommodation" value="@opt.v" class="hidden" required>
                                    </div>
                                }
                            </div>

                            <div class="mt-5 flex justify-between">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(6)">Back</button>
                                <button type="button" class="btn btn-orange px-5 py-3 text-lg" onclick="goToStep(8)">Next</button>
                            </div>
                        </div>

                        <!-- STEP 8: Final Logistics -->
                        <div class="step-content" id="step8">
                            <h1 class="font-bold text-navy mb-2" style="font-size: 2.5rem;">Final Details</h1>
                            <p class="text-gray-500 mb-5 text-lg">Tell us a bit more about your preferences</p>
                            
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Transportation</label>
                                    <select asp-for="Preferences.TransportationPreference" class="form-select" required>
                                        <option value="">Select Transport</option>
                                        <option value="Public Transportation">Public Transportation (Bus, Metro)</option>
                                        <option value="Private Car">Private Car / Uber</option>
                                        <option value="Domestic Flights">Domestic Flights</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Trip Pace</label>
                                    <select asp-for="Preferences.Intensity" class="form-select" required>
                                        <option value="Relaxed">Relaxed (Easy going)</option>
                                        <option value="Moderate">Moderate (Active)</option>
                                        <option value="Fast">Intensive (Pack Everything)</option>
                                    </select>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Dietary Preferences</label>
                                    <input type="text" asp-for="Preferences.FoodPreferences" class="form-control" placeholder="e.g., Vegetarian (Optional)">
                                </div>
                                <div>
                                    <label class="block font-bold mb-2 text-lg">Must-Visit Places</label>
                                    <input type="text" asp-for="Preferences.MustVisit" class="form-control" placeholder="e.g., Pyramids (Optional)">
                                </div>
                            </div>

                            <div class="flex justify-between mt-5">
                                <button type="button" class="btn btn-light px-5 py-3 text-lg" onclick="goToStep(7)">Back</button>
                                <button type="submit" class="btn btn-success btn-lg px-5 py-3 text-xl font-bold" onclick="showLoading()">Generate Plan ✨</button>
                            </div>
                        </div>
                    </form>

                    <!-- Global Inline Error Banner -->
                    <div id="validation-error-banner" class="hidden mt-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 flex items-start shadow-sm transition-all">
                        <svg class="w-6 h-6 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                        <span id="validation-error-text" class="font-medium text-lg leading-relaxed"></span>
                    </div>

                    <div id="loadingOverlay" style="display: none;" class="text-center py-10">
                        <div class="spinner-border text-orange-500" role="status" style="width: 4rem; height: 4rem;"></div>
                        <h2 class="font-bold text-navy mt-6 text-2xl">Creating your Egyptian adventure...</h2>
                        <p class="text-gray-500 mt-2 text-lg">Our AI is crafting your personalized itinerary.</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* --- RESULT VIEW --- *@
        <partial name="_TripResult" model="Model.GeneratedPlan" />

        <div class="text-center mt-5">
            <a asp-page="/Planner" class="btn btn-navy px-4">Start New Plan</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function selectCard(card) {
            const cb = card.querySelector('input[type="checkbox"]');
            if (cb) {
                cb.checked = !cb.checked;
                card.classList.toggle('selected', cb.checked);
            }
        }

        function selectRadio(card) {
            const stepContainer = card.closest('.step-content') || card.closest('.grid') || card.closest('.dynamic-group');
            if(stepContainer) {
                // Only uncheck sibling cards that are ALSO radio buttons
                stepContainer.querySelectorAll('.destination-card').forEach(c => {
                    if (c.querySelector('input[type="radio"]')) {
                        c.classList.remove('selected');
                    }
                });
            }

            const rb = card.querySelector('input[type="radio"]');
            if (rb) {
                rb.checked = true;
                card.classList.add('selected');

                // If this is a budget selection, filter accommodations
                if (rb.name === 'Preferences.Budget') {
                    filterAccommodations();
                }
            }
        }

        const destinationStyleMap = {
            'Alexandria': ['Historical', 'Cultural', 'Sea & Beach', 'Food & Dining'],
            'Cairo & Giza': ['Historical', 'Cultural', 'Shopping', 'Nightlife', 'Food & Dining'],
            'Luxor': ['Historical', 'Cultural'],
            'Aswan': ['Historical', 'Cultural', 'Nature'],
            'Sharm El-Sheikh': ['Sea & Beach', 'Nightlife', 'Adventure / Safari', 'Nature'],
            'Siwa Oasis': ['Nature', 'Adventure / Safari', 'Cultural', 'Historical']
        };

        function handleStyleChange() {
            const checkedStyles = Array.from(document.querySelectorAll('input[name="Preferences.TravelStyles"]:checked')).map(el => el.value);

            const hasSeaAndBeach = checkedStyles.includes('Sea & Beach');
            const hasCulturalOrHistorical = checkedStyles.includes('Cultural') || checkedStyles.includes('Historical');

            // Toggle Sea & Beach
            const seaBeachContainer = document.getElementById('seaAndBeachFields');
            if (hasSeaAndBeach) {
                seaBeachContainer.style.display = 'block';
            } else {
                seaBeachContainer.style.display = 'none';
                // Prune its fields
                seaBeachContainer.querySelectorAll('input[type="radio"]').forEach(el => {
                    el.checked = false;
                    const card = el.closest('.destination-card');
                    if(card) card.classList.remove('selected');
                });
            }

            // Toggle Cultural
            const culturalContainer = document.getElementById('culturalFields');
            if (hasCulturalOrHistorical) {
                culturalContainer.style.display = 'block';
            } else {
                culturalContainer.style.display = 'none';
                // Prune its fields
                document.getElementById('Preferences_HistoricalKnowledge').value = '';
                culturalContainer.querySelectorAll('input[type="radio"], input[type="checkbox"]').forEach(el => {
                    el.checked = false;
                    const card = el.closest('.destination-card');
                    if(card) card.classList.remove('selected');
                });
            }

            // No dynamic fields message
            if (!hasSeaAndBeach && !hasCulturalOrHistorical && checkedStyles.length > 0) {
                document.getElementById('noDynamicFields').style.display = 'block';
            } else {
                document.getElementById('noDynamicFields').style.display = 'none';
            }
        }

        function showError(msg) {
            const errBanner = document.getElementById('validation-error-banner');
            const errText = document.getElementById('validation-error-text');
            if(errBanner && errText) {
                errText.innerText = msg;
                errBanner.classList.remove('hidden');
                
                // Optional logic: auto-hide after 5 seconds if desired:
                // setTimeout(() => { errBanner.classList.add('hidden'); }, 5000);
            }
        }

        function hideError() {
            const errBanner = document.getElementById('validation-error-banner');
            if(errBanner) errBanner.classList.add('hidden');
        }

        function validateCurrentStep(currentStep) {
            hideError();
            if (currentStep === 1) {
                const checked = document.querySelectorAll('input[name="Preferences.Destinations"]:checked');
                if (checked.length === 0) { showError("Please select at least one destination."); return false; }
            } else if (currentStep === 2) {
                const start = document.getElementById('Preferences_StartDate').value;
                const end = document.getElementById('Preferences_EndDate').value;
                if (!start || !end) { showError("Please select both start and end dates."); return false; }
                if (new Date(start) > new Date(end)) { showError("End date must be after start date."); return false; }
            } else if (currentStep === 3) {
                const adults = document.getElementById('Preferences_Travelers_Adults').value;
                if (!adults || parseInt(adults) < 1) { showError("Please enter at least 1 adult traveler."); return false; }
            } else if (currentStep === 4) {
                const budget = document.querySelector('input[name="Preferences.Budget"]:checked');
                if (!budget) { showError("Please select a budget range."); return false; }
            } else if (currentStep === 5) {
                const checkedStyles = document.querySelectorAll('input[name="Preferences.TravelStyles"]:checked');
                if(checkedStyles.length === 0) { showError("Please select at least one travel style."); return false; }
            } else if (currentStep === 6) {
                const checkedStyles = Array.from(document.querySelectorAll('input[name="Preferences.TravelStyles"]:checked')).map(el => el.value);
                
                if (checkedStyles.includes('Sea & Beach')) {
                    if(!document.querySelector('input[name="Preferences.WantsWaterActivities"]:checked')) {
                        showError("Please select if you want water activities.");
                        return false;
                    }
                }
                
                if (checkedStyles.includes('Cultural') || checkedStyles.includes('Historical')) {
                    if(!document.getElementById('Preferences_HistoricalKnowledge').value) {
                        showError("Please select your historical knowledge level.");
                        return false;
                    }
                    const chks = document.querySelectorAll('input[name="Preferences.PreferredTourismStyle"]:checked');
                    if(chks.length === 0) {
                        showError("Please select at least one preferred tourism style.");
                        return false;
                    }
                    if(!document.querySelector('input[name="Preferences.MuseumPreferences"]:checked')) {
                        showError("Please select your museum preference.");
                        return false;
                    }
                }
            } else if (currentStep === 7) {
                const acc = document.querySelector('input[name="Preferences.Accommodation"]:checked');
                if (!acc) { showError("Please select your preferred accommodation."); return false; }
            }
            return true;
        }

        async function loadBudgetRanges() {
            try {
                const destinations = Array.from(document.querySelectorAll('input[name="Preferences.Destinations"]:checked')).map(el => el.value).join(',');
                const startDate = document.querySelector('input[name="Preferences.StartDate"]').value;
                const endDate = document.querySelector('input[name="Preferences.EndDate"]').value;
                const adults = parseInt(document.querySelector('input[name="Preferences.Travelers.Adults"]').value) || 2;
                const kids = parseInt(document.querySelector('input[name="Preferences.Travelers.Kids"]').value) || 0;

                if (!destinations) {
                    showError("Please select at least one destination.");
                    return;
                }

                if (!startDate || !endDate) {
                    showError("Please select travel dates.");
                    return;
                }

                const days = Math.max(1, Math.ceil((new Date(endDate) - new Date(startDate)) / (1000 * 60 * 60 * 24)) + 1);

                const response = await fetch(`/Planner?handler=CalculateBudgetRange&destinations=${encodeURIComponent(destinations)}&days=${days}&adults=${adults}&kids=${kids}&startDate=${encodeURIComponent(startDate)}`);
                const data = await response.json();

                if (!data.success) {
                    showError(data.message || "Failed to calculate budget ranges.");
                    return;
                }

                const container = document.getElementById('budgetRangesContainer');
                container.innerHTML = '';

                data.budgetRanges.forEach(range => {
                    const card = document.createElement('div');
                    card.className = 'destination-card p-5 text-center shadow-sm flex flex-col items-center justify-center cursor-pointer transition-all bg-white rounded-xl';
                    card.onclick = function() { selectRadio(this); };

                    // Tier badge (Budget / Mid-Range / Comfortable / Luxury)
                    const tierBadge = document.createElement('span');
                    tierBadge.className = 'text-xs font-semibold uppercase tracking-widest mb-1 text-orange-500';
                    tierBadge.textContent = range.tier || '';

                    const label = document.createElement('h3');
                    label.className = 'font-bold text-lg m-0 text-navy';
                    label.textContent = range.label;

                    const input = document.createElement('input');
                    input.type = 'radio';
                    input.name = 'Preferences.Budget';
                    // Store clean numeric value "min–max" (no EGP, no commas) for reliable server parsing
                    input.value = `${range.min}–${range.max}`;
                    input.className = 'hidden';
                    input.required = true;

                    card.appendChild(tierBadge);
                    card.appendChild(label);
                    card.appendChild(input);
                    container.appendChild(card);
                });

                // Update the budget accommodation map with the new ranges
                updateBudgetAccommodationMap(data.budgetRanges);
            } catch (error) {
                console.error('Error loading budget ranges:', error);
                showError("Failed to load budget ranges. Please try again.");
            }
        }

        function updateBudgetAccommodationMap(budgetRanges) {
            window.budgetAccommodationMap = {};
            budgetRanges.forEach((range) => {
                const key = `${range.min}–${range.max}`;
                const tier = (range.tier || '').toLowerCase();
                if (tier === 'budget') {
                    window.budgetAccommodationMap[key] = ['Hostel / Budget', 'Local Guesthouses'];
                } else if (tier === 'mid-range') {
                    window.budgetAccommodationMap[key] = ['Hostel / Budget', 'Local Guesthouses', 'Mid-Range (3-4 Stars)'];
                } else {
                    // Comfortable & Luxury — all options available
                    window.budgetAccommodationMap[key] = ['Hostel / Budget', 'Local Guesthouses', 'Mid-Range (3-4 Stars)', 'Luxury (5 Stars)'];
                }
            });
        }

        function filterTravelStyles() {
            // Get selected destinations
            const selectedDestinations = Array.from(document.querySelectorAll('input[name="Preferences.Destinations"]:checked')).map(el => el.value);
            
            // Collect allowed styles for all selected destinations
            let allowedStyles = new Set();
            let allUnknown = true; // If they select a city not in the map, default to showing everything

            selectedDestinations.forEach(dest => {
                if (destinationStyleMap[dest]) {
                    destinationStyleMap[dest].forEach(style => allowedStyles.add(style));
                    allUnknown = false;
                }
            });

            // Update UI for the checkboxes
            const styleCards = document.querySelectorAll('.travel-style-card');
            styleCards.forEach(card => {
                const styleName = card.getAttribute('data-style');
                if (allUnknown || allowedStyles.has(styleName)) {
                    card.style.display = 'flex'; // show
                } else {
                    card.style.display = 'none'; // hide
                    // Uncheck if it was previously selected
                    const cb = card.querySelector('input[type="checkbox"]');
                    if (cb && cb.checked) {
                        cb.checked = false;
                        card.classList.remove('selected');
                    }
                }
            });
            handleStyleChange(); // update dynamic branches based on potential un-checks
        }

        const budgetAccommodationMap = {
            '500-1000 EGP': ['Hostel / Budget', 'Local Guesthouses'],
            '1000-2000 EGP': ['Hostel / Budget', 'Local Guesthouses', 'Mid-Range (3-4 Stars)'],
            '2000-5000 EGP': ['Hostel / Budget', 'Local Guesthouses', 'Mid-Range (3-4 Stars)', 'Luxury (5 Stars)'],
            '5000+ EGP': ['Hostel / Budget', 'Local Guesthouses', 'Mid-Range (3-4 Stars)', 'Luxury (5 Stars)']
        };

        function filterAccommodations() {
            const budgetChecked = document.querySelector('input[name="Preferences.Budget"]:checked');
            if(!budgetChecked) return;

            const selectedBudget = budgetChecked.value;
            const allowedAcc = (window.budgetAccommodationMap && window.budgetAccommodationMap[selectedBudget]) || budgetAccommodationMap[selectedBudget] || [];

            const accCards = document.querySelectorAll('.accommodation-card');
            accCards.forEach(card => {
                const label = card.getAttribute('data-label');
                if (allowedAcc.includes(label)) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                    const rb = card.querySelector('input[type="radio"]');
                    if (rb && rb.checked) {
                        rb.checked = false;
                        card.classList.remove('selected');
                    }
                }
            });
        }
        const regionMap = {
            'Cairo & Giza': 1,
            'Alexandria': 1,
            'Luxor': 2,
            'Aswan': 2,
            'Sharm El-Sheikh': 3,
            'Siwa Oasis': 4
        };

        function calculateMinDays(selectedCities) {
            if (!selectedCities || selectedCities.length === 0) return 0;
            if (selectedCities.length === 1) return 1;
            let baseDays = selectedCities.length * 2;
            let expectedRegions = new Set();
            
            selectedCities.forEach(city => {
                if (regionMap[city]) expectedRegions.add(regionMap[city]);
            });
            
            let travelPenalty = expectedRegions.size > 1 ? expectedRegions.size - 1 : 0;
            return baseDays + travelPenalty;
        }

        function getLocalYMD(d) {
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const dd = String(d.getDate()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}`;
        }

        function updateMinEndDate() {
            const startDateInput = document.getElementById('Preferences_StartDate');
            const endDateInput = document.getElementById('Preferences_EndDate');
            if (!startDateInput || !endDateInput) return;

            if (!startDateInput.value) {
                const tomorrow = new Date();
                tomorrow.setDate(tomorrow.getDate() + 1);
                endDateInput.min = getLocalYMD(tomorrow);
                return;
            }

            const selectedDestinations = Array.from(document.querySelectorAll('input[name="Preferences.Destinations"]:checked')).map(el => el.value);
            const minTripDays = calculateMinDays(selectedDestinations);

            const [y, m, d] = startDateInput.value.split('-');
            const localStartDate = new Date(y, m - 1, d);
            localStartDate.setDate(localStartDate.getDate() + Math.max(0, minTripDays - 1));
            
            const yyyy = localStartDate.getFullYear();
            const mm = String(localStartDate.getMonth() + 1).padStart(2, '0');
            const dd = String(localStartDate.getDate()).padStart(2, '0');
            const minEndDateStr = `${yyyy}-${mm}-${dd}`;

            endDateInput.min = minEndDateStr;

            if (endDateInput.value && endDateInput.value < minEndDateStr) {
                endDateInput.value = '';
                showError(`Please select a new end date. This trip requires at least ${minTripDays} days based on your selected destinations.`);
            }
        }

        function goToStep(targetStep) {
            const activeDiv = document.querySelector('.step-content.active');
            const currentStepNum = parseInt(activeDiv.id.replace('step', ''));

            // Validate if trying to move forward
            if (targetStep > currentStepNum) {
                if (!validateCurrentStep(currentStepNum)) return;
            }

            if (targetStep === 2) {
                updateMinEndDate();
            } else if (targetStep === 4) {
                loadBudgetRanges();
            } else if (targetStep === 5) {
                filterTravelStyles();
            } else if (targetStep === 6) {
                // If attempting to go to step 6, check if it's needed
                const noDynamicFields = document.getElementById('noDynamicFields');
                if (noDynamicFields && noDynamicFields.style.display === 'block') {
                    // Skip step 6
                    if (targetStep > currentStepNum) {
                        targetStep = 7; // Moving forward -> go to 7
                        filterAccommodations(); // We are effectively entering step 7 now
                    } else {
                        targetStep = 5; // Moving backward -> go to 5
                        filterTravelStyles(); // We are entering step 5
                    }
                }
            } else if (targetStep === 7) {
                filterAccommodations();
            }

            const target = document.getElementById('step' + targetStep);
            if (target) {
                document.querySelectorAll('.step-content').forEach(s => s.classList.remove('active'));
                target.classList.add('active');

                document.getElementById('stepText').innerText = `Step ${targetStep} of 8`;
                const percentage = Math.round(((targetStep - 1) / 8) * 100);
                document.getElementById('progressText').innerText = `${percentage > 0 ? percentage : 13}% Complete`;
                document.getElementById('pBar').style.width = (targetStep / 8 * 100) + '%';

                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        function showLoading() {
            if (!validateCurrentStep(8)) return; // Wait, step 8 validation wasn't strictly checked above. Actually, HTML5 'required' will handle step 8 natively before this fires. Let's just trust HTML5.
            
            document.getElementById('plannerForm').style.display = 'none';
            document.getElementById('loadingOverlay').style.display = 'block';
            document.getElementById('stepText').parentElement.style.display = 'none';
            document.getElementById('pBar').parentElement.style.display = 'none';
        }

        document.addEventListener('DOMContentLoaded', function() {
            const startDateInput = document.getElementById('Preferences_StartDate');
            const endDateInput = document.getElementById('Preferences_EndDate');
            
            if (startDateInput && endDateInput) {
                function updateMinsDynamically() {
                    const tomorrow = new Date();
                    tomorrow.setDate(tomorrow.getDate() + 1);
                    const tomorrowStr = getLocalYMD(tomorrow);
                    
                    startDateInput.min = tomorrowStr;
                    
                    if (!startDateInput.value) {
                        endDateInput.min = tomorrowStr;
                    }
                }

                // Set initial
                updateMinsDynamically();
                
                // Update dynamically if user interacts past midnight
                startDateInput.addEventListener('focus', updateMinsDynamically);
                startDateInput.addEventListener('click', updateMinsDynamically);

                // When start date changes, update end date's min attribute dynamically based on required days
                startDateInput.addEventListener('change', function() {
                    updateMinEndDate();
                });
            }

            @if (!ModelState.IsValid)
            {
                <text>
                // Show errors from server-side validation or generation failures
                showError("Generation failed or invalid inputs. Please try again.");
                goToStep(8);
                // Reset loading overlay
                document.getElementById('plannerForm').style.display = 'block';
                document.getElementById('loadingOverlay').style.display = 'none';
                document.getElementById('stepText').parentElement.style.display = 'flex';
                document.getElementById('pBar').parentElement.style.display = 'block';
                </text>
            }
        });
    </script>
}