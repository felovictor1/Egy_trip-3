                                        ? rest.imageUrl.ToString()
                                        : $"https://source.unsplash.com/400x200/?egypt,restaurant,{Uri.EscapeDataString(restName)}";
                                    <div class="bg-white dark:bg-slate-800 border-b border-gray-100 dark:border-white/5 last:border-0 flex flex-col overflow-hidden">
                                        <img src="@imgSrc"
                                             class="w-full h-32 object-cover"
                                             alt="@restName"
                                             onerror="this.style.display='none'"
                                             loading="lazy" />
                                        <div class="p-4">
                                            <div class="flex justify-between items-start gap-2">
                                                <div class="flex-grow">
                                                    <h4 class="font-bold text-navy dark:text-white text-sm mb-1 leading-tight">@restName</h4>
                                                    @if (!string.IsNullOrEmpty(rest?.cuisines?.ToString()))
                                                    {
                                                        <p class="text-gray-500 dark:text-gray-400 text-xs mb-1">🍴 @rest.cuisines</p>
