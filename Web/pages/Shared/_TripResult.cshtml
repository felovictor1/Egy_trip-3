        @if (requiresPayment)
        {
            @Html.Raw("</div></div>")
        }

        @* Only show raw AI output if we have NO structured activities to display *@
        @if ((trip.itinerary == null) && (Model.Activities == null || !Model.Activities.Any()))
        {
            if (trip.content != null && !string.IsNullOrEmpty(trip.content.ToString()))
            {
                <div class="mt-12 p-8 bg-white dark:bg-slate-800 rounded-2xl shadow-lg border border-gray-100 dark:border-white/10">
                    <h3 class="text-2xl font-bold text-navy dark:text-white mb-6 flex items-center gap-2"><span>🤖</span> Full AI Response Details</h3>
                    <div id="markdown-content" class="text-gray-800 dark:text-gray-300 leading-relaxed" style="font-family: inherit;">
                        <style>
                            #markdown-content h1, #markdown-content h2, #markdown-content h3 { font-weight: bold; margin-top: 1.5rem; margin-bottom: 1rem; color: inherit; }
                            #markdown-content h1 { font-size: 1.8rem; }
                            #markdown-content h2 { font-size: 1.5rem; }
                            #markdown-content h3 { font-size: 1.25rem; }
                            #markdown-content p { margin-bottom: 1rem; }
                            #markdown-content ul { list-style-type: disc; padding-left: 2rem; margin-bottom: 1rem; }
                            #markdown-content li { margin-bottom: 0.5rem; }
                            #markdown-content strong { font-weight: bold; color: inherit; }
                        </style>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Render Raw AI Output
        var rawMarkdown = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(trip.content != null ? trip.content.ToString() : ""));
        if (rawMarkdown && rawMarkdown.trim() !== '') {
            var mdContainer = document.getElementById('markdown-content');
            if (mdContainer) {
                // Keep the style tag inside by appending the HTML
                var renderedHtml = marked.parse(rawMarkdown);
                mdContainer.innerHTML = mdContainer.innerHTML + renderedHtml;
            }
        }

        // Initialize SortableJS
        const containers = document.querySelectorAll('.sortable-day-container');
        containers.forEach(container => {
            new Sortable(container, {
                group: 'shared', // set both lists to same group
                animation: 150,
                ghostClass: 'opacity-50',
                dragClass: 'shadow-2xl',
                handle: '.activity-box'
            });
        });

        // Handle Save Order
        const saveBtn = document.getElementById('save-trip-order');
        if (saveBtn) {
            saveBtn.addEventListener('click', async function() {
                saveBtn.disabled = true;
                const originalText = saveBtn.innerHTML;
                saveBtn.innerHTML = '<span>⏳</span> Saving...';

                const updates = [];
                const dayContainers = document.querySelectorAll('.sortable-day-container');
                
                dayContainers.forEach(container => {
                    const dayNum = parseInt(container.getAttribute('data-day'));
                    const items = container.querySelectorAll('.timeline-item');
                    
                    items.forEach((item, index) => {
                        const activityId = parseInt(item.getAttribute('data-activity-id'));
                        if (activityId > 0) {
                            updates.push({
                                ActivityId: activityId,
                                NewDay: dayNum,
                                NewOrder: index + 1
                            });
                        }
                    });
                });

                if (updates.length === 0) {
                    alert("No valid activities found to save.");
                    saveBtn.innerHTML = originalText;
                    saveBtn.disabled = false;
                    return;
                }

                // Get Antiforgery Token
                const token = document.querySelector('#antiforgery-form input[name="__RequestVerificationToken"]')?.value;

                try {
                    const response = await fetch('?handler=SaveTripEdit', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token || ''
                        },
                        body: JSON.stringify(updates)
                    });

                    const result = await response.json();
                    if (result.success) {
                        saveBtn.innerHTML = '<span>✅</span> Saved!';
                        saveBtn.classList.remove('bg-orange', 'hover:bg-orange/90');
                        saveBtn.classList.add('bg-green-600', 'hover:bg-green-700');
                        
                        setTimeout(() => {
                            saveBtn.innerHTML = originalText;
                            saveBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
                            saveBtn.classList.add('bg-orange', 'hover:bg-orange/90');
                            saveBtn.disabled = false;
                        }, 3000);
                    } else {
                        throw new Error(result.message || "Unknown error occurred");
                    }
                } catch (error) {
                    console.error('Save failed:', error);
                    alert('Failed to save trip order: ' + error.message);
                                                    saveBtn.innerHTML = originalText;
                    saveBtn.disabled = false;
                }
            });
        }
        // ── Weather Widget ────────────────────────────────────────────────────────
        (async function loadWeather() {
            const container   = document.getElementById('trip-result-container');
            if (!container) return;

            const destination = container.dataset.destination;
            const startDate   = container.dataset.startDate;
            const days        = parseInt(container.dataset.days) || 3;

            if (!destination || !startDate) return;

            try {
                const params = new URLSearchParams({
                    handler:     'Weather',
                    destination: destination,
                    startDate:   startDate,
                    days:        Math.min(days, 14)
                });

                const res  = await fetch(`/Planner?${params}`);
                if (!res.ok) return;
                const data = await res.json();     // Array of DailyWeatherDto
                if (!Array.isArray(data) || data.length === 0) return;

                // Match by DayNumber (server-tagged) — immune to array length variations
                document.querySelectorAll('.weather-badge').forEach(badge => {
                    const dayNum = parseInt(badge.dataset.day);
                    const w      = data.find(d => d.dayNumber === dayNum);
                    if (!w) return;

                    const rainHtml = w.rainChance > 20
                        ? `<span class="text-blue-500">💧${w.rainChance}%</span>`
                        : '';

                    badge.innerHTML = `
                        <img src="${w.iconUrl}" alt="${w.condition}" class="w-7 h-7" />
                        <span class="font-semibold">${Math.round(w.maxTempC)}°C</span>
                        <span class="text-xs text-gray-400">/ ${Math.round(w.minTempC)}°C</span>
                        <span class="text-xs hidden sm:inline">${w.condition}</span>
                        ${rainHtml}
                    `;
                    badge.style.display        = 'flex';
                    badge.style.alignItems     = 'center';
                    badge.style.gap            = '6px';
                    badge.style.fontSize       = '0.85rem';
                    badge.style.background     = 'rgba(59,130,246,0.08)';
                    badge.style.borderRadius   = '999px';
                    badge.style.padding        = '2px 10px';
                    badge.style.border         = '1px solid rgba(59,130,246,0.15)';
                });

            } catch (e) {
                // Silent — weather is optional; never break the page
                console.warn('[Weather]', e);
            }
        })();
    });
</script>