                                                    <h4 class="font-bold text-navy dark:text-white text-sm mb-1 leading-tight">@act.Place</h4>
                                                    @{
                                                        var placeData = mlPlaces.FirstOrDefault(p => (p?.name?.ToString() ?? "").Equals(act.Place, StringComparison.OrdinalIgnoreCase));
